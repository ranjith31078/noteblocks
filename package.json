{
  "name": "noteblocks-web",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "semgrep": "semgrep --config semgrep.yml --error --exclude node_modules --exclude .next .",
    "audit": "npm audit --audit-level=high",
    "quality:prod": "npm run lint && npm run typecheck && npm run semgrep && npm run audit",
    "build:app": "next build",
    "build": "npm run quality:prod && npm run build:app",
    "start": "next start"
  },
  "dependencies": {
    "@mantine/core": "^7.15.2",
    "@mantine/hooks": "^7.15.2",
    "@tabler/icons-react": "^3.36.1",
    "better-sqlite3": "^12.6.2",
    "next": "^15.2.0",
    "quill": "^2.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.21.0",
    "eslint-plugin-no-secrets": "^2.1.2",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.2",
    "globals": "^16.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1"
  }
}
